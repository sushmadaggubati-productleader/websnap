# ── Google OAuth ────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/
#   1. New project → APIs & Services → Credentials → Create OAuth 2.0 Client ID
#   2. Application type: Web application
#   3. Authorised redirect URI: http://localhost:8000/auth/google/callback
#      (add your production domain too, e.g. https://yourapp.railway.app/auth/google/callback)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── App secret ──────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-hex-string

# ── Free tier ───────────────────────────────────────────────────────────────
FREE_TIER_LIMIT=5

# ── Stripe (leave commented until you're ready to charge) ───────────────────
# Sign up at https://stripe.com, get keys from the Dashboard → Developers
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID=price_...        # recurring price for your Pro plan
# STRIPE_WEBHOOK_SECRET=whsec_...  # from Stripe CLI or Dashboard webhooks

# ── Set to "true" only in production (HTTPS) ────────────────────────────────
COOKIE_SECURE=false

# ── Anthropic (already needed by agent.py) ───────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
